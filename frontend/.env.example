# Frontend -> Python backend read-only bridge.
HUNTER_API_BASE_URL="http://127.0.0.1:8787"

# Optional public site URL.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Backend runtime overrides.
# Use this when Binance REST must go through your VPN/proxy.
HUNTER_NETWORK_PROXY=""
HUNTER_DB_PATH="backend/storage/hunter.db"
HUNTER_ALERTS_DIR="backend/alerts"

# Optional WeCom alert push.
WECOM_WEBHOOK_URL=""
