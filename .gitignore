# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ---- frontend (Next.js) ----
/frontend/node_modules
/frontend/.npm-cache
/frontend/.pnpm-store
/frontend/.pnp
/frontend/.pnp.*
/frontend/.next/
/frontend/out/
/frontend/build
/frontend/coverage
/frontend/.vercel
/frontend/*.tsbuildinfo
/frontend/next-env.d.ts

# ---- backend (Python) hunter runtime data ----
/backend/.venv/
/backend/storage/*
!/backend/storage/.gitkeep
/backend/alerts/*
!/backend/alerts/.gitkeep
/backend/data/cache/*
!/backend/data/cache/.gitkeep
/backend/reports/*
!/backend/reports/.gitkeep
/backend/**/__pycache__/
/backend/**/*.py[cod]

# ---- env files (opt-in commit via .env.example) ----
.env
.env.*
!.env.example

# ---- misc ----
.DS_Store
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ---- agent tooling ----
.playwright-mcp/
.superpowers/
.superpowers-brainstorm/
