[Unit]
Description=Binance pump-dump hunter read-only API
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/pixel-canvas/pixel-canvas/backend/hunter
EnvironmentFile=/etc/binance-hunter.env
ExecStart=/opt/pixel-canvas/pixel-canvas/backend/hunter/.venv/bin/python run.py web --config config/settings.json --host 127.0.0.1 --port 8787
Restart=always
RestartSec=5
User=root
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
